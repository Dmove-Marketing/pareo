---
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import LeadForm from '../components/forms/LeadForm.astro';
import { getImage } from 'astro:assets';
import rawDmove from '../assets/images/Versao-Principal-Negativo-scaled-e1750426923582.avif';
const dmoveLogo = await getImage({ src: rawDmove, format: 'avif' });
const LOGO_SRC  = 'https://media.dmove.com.br/clients/restaurantepareo/photos/logo.webp';
const HERO_SRC  = 'https://media.dmove.com.br/clients/restaurantepareo/photos/IMG-20260617-WA0059.webp';
import '../styles/bio.css';

const MAPS_URL = 'https://maps.google.com/?q=Rua+Mario+Ribeiro,+410,+Jockey+Club+Brasileiro,+Rio+de+Janeiro,+RJ,+22470-060';
const SITE_URL  = 'https://restaurantepareo.com.br/';
---

<Base
  title="Páreo Buffet · Casamentos e Eventos Sociais no Jockey Club"
  description="Celebre grandes momentos dentro do Jockey Club Brasileiro com o Páreo Buffet. Casamentos, 15 anos e aniversários no endereço mais especial do Rio."
  ogImage="/images/og-index.jpg"
  noIndex={true}
  whatsappFormId="whats-social"
>
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400&family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- HERO -->
  <section class="bio-hero">
    <img src={HERO_SRC} alt="Salão do Páreo preparado para evento social no Jockey Club" class="bio-hero-img" style="object-position: center center;" />
    <div class="bio-hero-overlay"></div>
    <div class="bio-hero-content">
      <img src={LOGO_SRC} alt="Páreo" class="bio-logo" />
      <span class="bio-eyebrow">Páreo Buffet · Jockey Club Brasileiro</span>
      <h1 class="bio-headline">Celebre grandes momentos dentro do Jockey Club Brasileiro</h1>
      <p class="bio-subline">Casamentos &nbsp;|&nbsp; 15 anos &nbsp;|&nbsp; Aniversários</p>
    </div>
  </section>

  <!-- BOTÕES -->
  <section class="bio-links-section">
    <div class="bio-links">
      <a
        href={MAPS_URL}
        target="_blank"
        rel="noopener"
        class="bio-link-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Rua Mario Ribeiro, 410 · Jockey Club · RJ
      </a>

      <a
        href={SITE_URL}
        target="_blank"
        rel="noopener"
        class="bio-link-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        restaurantepareo.com.br
      </a>

    </div>
  </section>

  <!-- FORMULÁRIO -->
  <section class="bio-form-section" id="solicitar">
    <p class="bio-section-label">Fale conosco</p>
    <h2 class="bio-section-title">Solicite um orçamento</h2>
    <LeadForm
      formId="lead-form"
      class="bio-form-card"
      prefix="bio"
      project={config.project_slug}
      submitUrl={config.forms['lead-form'].webhooks[0]}
      redirectUrl={config.forms['lead-form'].redirect_on_success}
      submitText="Solicitar orçamento"
      honeypot
      fields={[
        { name: 'nome',     type: 'text',  label: 'Nome completo', placeholder: 'Seu nome', required: true, full: true },
        { type: 'row', fields: [
          { name: 'telefone', id: 'whatsapp', type: 'tel',   label: 'WhatsApp', placeholder: '(00) 00000-0000', required: true },
          { name: 'email',                    type: 'email', label: 'E-mail',   placeholder: 'seu@email.com',   required: true }
        ]},
        { name: 'tipo', type: 'select', label: 'Tipo de evento', required: true, full: true, options: [
          { value: '',                        label: 'Tipo de evento'         },
          { value: 'Aniversário',             label: 'Aniversário'            },
          { value: 'Aniversário debutante',   label: 'Aniversário debutante'  },
          { value: 'Bodas',                   label: 'Bodas'                  },
          { value: 'Casamento',               label: 'Casamento'              },
          { value: 'Confraternização social', label: 'Confraternização social' },
          { value: 'Formatura',               label: 'Formatura'              },
          { value: 'Shows e Festivais',       label: 'Shows e Festivais'      },
          { value: 'Outros',                  label: 'Outros'                 }
        ]},
        { type: 'row', fields: [
          { name: 'data',       type: 'date',   label: 'Data do evento',   placeholder: 'dd/mm/aaaa', required: true },
          { name: 'convidados', type: 'number', label: 'Nº de convidados', placeholder: 'Ex: 150',    required: true }
        ]},
        { name: 'mensagem', type: 'textarea', label: 'Mensagem', placeholder: 'Detalhes adicionais (não obrigatório)', required: false, full: true }
      ]}
    />
  </section>

  <!-- FOOTER -->
  <footer class="bio-footer">
    <div class="bio-footer__top">
      <img src={LOGO_SRC} alt="Páreo" class="bio-footer__logo" />
      <div class="bio-social">
        <a href="https://www.instagram.com/pareo.buffet/" target="_blank" rel="noopener" class="bio-social-btn" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/restaurantepareo/" target="_blank" rel="noopener" class="bio-social-btn" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>
      </div>
      <div class="bio-footer__bottom">
        <p class="bio-footer__copy">&copy; 2026 Páreo. Todos os direitos reservados.</p>
        <a href="https://dmove.com.br/" target="_blank" rel="noopener noreferrer" class="bio-footer__dmove">
          Desenvolvido por
          <img src={dmoveLogo.src} alt="Dmove" class="bio-footer__dmove-logo" width="60" height="13" />
        </a>
      </div>
    </div>
  </footer>

</Base>

<script>
  import '../scripts/bio.js';
</script>
