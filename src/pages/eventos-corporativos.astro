---
// Gerado a partir de: eventos-corporativos.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/eventos-corporativos.css';
---

<Base
  title="Páreo · Eventos Corporativos no Jockey Club"
  description="Dentro do Jockey Club, a Páreo transforma o seu evento corporativo em uma celebração memorável. Restaurante e Salão Nobre no endereço mais prestigiado do Rio de Janeiro."
  ogImage="hero.webp"
  whatsappFormId="whats-corporativos"
  whatsappShowEmpresa={true}
  whatsappEventOptions={[
    { value: 'Convenção corporativa',           label: 'Convenção corporativa'          },
    { value: 'Confraternização / Fim de ano',   label: 'Confraternização / Fim de ano'  },
    { value: 'Premiação',                       label: 'Premiação'                      },
    { value: 'Reunião de negócios',             label: 'Reunião de negócios'            },
    { value: 'Lançamento de produto',           label: 'Lançamento de produto'          },
    { value: 'Happy Hours',                     label: 'Happy Hours'                    },
    { value: 'Masterclass e Palestras',         label: 'Masterclass e Palestras'        },
    { value: 'Offsite corporativo',             label: 'Offsite corporativo'            },
    { value: 'Outro',                           label: 'Outro'                          },
  ]}
>
<a class="skip" href="#conteudo">Pular para o conteúdo</a>

<!-- HEADER -->
<header id="header">
  <a href="#top" class="logo" aria-label="Páreo — página inicial"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo.webp" alt="Páreo" priority /></a>
</header>

<main id="conteudo">
<!-- HERO -->
<section class="hero" id="top">
  <div class="hero-bg"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/hero1.webp" alt="Salão da Páreo no Jockey Club preparado para evento corporativo" priority /></div>
  <div class="hero-inner">
    <span class="eyebrow">Eventos Corporativos</span>
    <h1 class="serif">Realize seu evento corporativo no endereço<br class="d-br"> mais prestigiado do Rio de Janeiro</h1>
    <p>Dentro do <b>Jockey Club</b>, a Páreo transforma o seu evento em uma celebração memorável.</p>
    <a href="#contato" class="btn btn-gold">Solicite um contato <span class="arrow">→</span></a>
  </div>
  <div class="scroll-cue" aria-hidden="true"><div class="line"></div></div>
</section>

<!-- O ESPAÇO -->
<section class="espaco section-pad">
  <div class="wrap espaco-grid">
    <div class="espaco-text reveal">
      <span class="eyebrow">O Espaço</span>
      <h2 class="serif">O lugar certo para<br>eventos de excelência</h2>
      <p>Poucos endereços no Rio de Janeiro carregam o prestígio do Jockey Club. É nesse cenário, entre a tradição de uma instituição centenária e a sofisticação da Zona Sul, que a Páreo recebe eventos corporativos de empresas que precisam mais que um espaço.</p>
      <p>Nesse contexto, a Páreo se desdobra em ambientes que se moldam a cada ocasião, do salão imponente para grandes celebrações ao espaço reservado para encontros executivos.</p>
    </div>
    <div class="espaco-imgs reveal d1">
      <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/sobre-aerea.webp" alt="Vista aérea do Jockey Club do Rio de Janeiro" /></figure>
    </div>
  </div>
</section>

<!-- AMBIENTES -->
<section class="ambientes section-pad">
  <div class="wrap">
    <div class="head-center reveal">
      <span class="eyebrow">Ambientes</span>
      <h2 class="serif">Várias possibilidades, uma só assinatura</h2>
      <p class="lead">Cada evento pede uma atmosfera própria. Por isso, sua empresa pode escolher entre dois locais distintos, ambos conduzidos pelo mesmo padrão de serviço.</p>
    </div>
    <div class="amb-grid">
      <article class="amb-card reveal">
        <div class="media"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/restaurante-pareo.webp" alt="O Restaurante da Páreo com varanda e teto retrátil" /></div>
        <div class="amb-body">
          <span class="num">Ambiente 01</span>
          <h3 class="serif">Páreo Lounge</h3>
          <p class="desc">Para reuniões de negócio e confraternizações, o nosso restaurante abre suas portas.</p>
          <ul class="amb-list">
            <li>Varanda com teto retrátil</li>
            <li>Alta gastronomia assinada pela casa</li>
            <li>Lounge aconchegante</li>
          </ul>
          <span class="amb-cap">Até <b>150</b> convidados</span>
        </div>
      </article>
      <article class="amb-card reveal d1">
        <div class="media"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/Varanda.webp" alt="Varanda Garden da Páreo com teto retrátil" /></div>
        <div class="amb-body">
          <span class="num">Ambiente 02</span>
          <h3 class="serif">Varanda Garden</h3>
          <p class="desc">Um espaço a céu aberto para celebrações sob o horizonte carioca.</p>
          <ul class="amb-list">
            <li>Vista para o horizonte</li>
            <li>Clima ao ar livre</li>
            <li>Ambiente reservado e sofisticado</li>
          </ul>
          <span class="amb-cap">Até <b>50</b> convidados</span>
        </div>
      </article>
      <article class="amb-card reveal d2">
        <div class="media"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/SalaoNobre.webp" alt="Salão Nobre da Páreo iluminado para convenção" /></div>
        <div class="amb-body">
          <span class="num">Ambiente 03</span>
          <h3 class="serif">Salão Nobre</h3>
          <p class="desc">Com 640m², é o palco ideal para convenções, premiações e festas de fim de ano.</p>
          <ul class="amb-list">
            <li>Pé-direito alto e arquitetura moderna</li>
            <li>Layout versátil para diferentes formatos</li>
            <li>Climatização em todo o salão</li>
          </ul>
          <span class="amb-cap">Até <b>400</b> convidados</span>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- GASTRONOMIA -->
<section class="gastro section-pad">
  <div class="wrap">
    <div class="head-center reveal">
      <span class="eyebrow">Gastronomia</span>
      <h2 class="serif">Gastronomia internacional com identidade brasileira</h2>
      <p class="lead">No comando da cozinha, o chef Marcones Deus assina a alta gastronomia do Páreo, combinando ingredientes clássicos com muita brasilidade e sotaques nacionais.</p>
    </div>
    <div class="carousel reveal" aria-label="Galeria de gastronomia">
      <div class="track-mask">
        <div class="track" id="track">
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro2.webp" alt="Prato da gastronomia Páreo" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro1.webp" alt="Corte nobre na parrilla" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro4.webp" alt="Preparo na cozinha Páreo" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro6.webp" alt="Detalhe de prato Páreo" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro5.webp" alt="Composição gastronômica Páreo" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro-6.webp" alt="Prato da gastronomia Páreo" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro-1.webp" alt="Corte nobre na parrilla" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro-5.webp" alt="Prato autoral do chef" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro-4.webp" alt="Preparo na cozinha Páreo" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro-2.webp" alt="Detalhe de prato Páreo" /></figure>
          <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gastro-3.webp" alt="Composição gastronômica Páreo" /></figure>
        </div>
      </div>
      <div class="carousel-nav">
        <button id="prev" aria-label="Anterior"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg></button>
        <button id="next" aria-label="Próximo"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg></button>
      </div>
    </div>
    <p class="gastro-foot reveal">O cardápio transita pela culinária brasileira e pelos cortes nobres na parrilla, sempre ajustado ao perfil de cada ocasião.</p>
  </div>
</section>

<!-- ESTRUTURA -->
<section class="estrutura section-pad">
  <div class="wrap">
    <div class="head-center reveal">
      <span class="eyebrow">Estrutura</span>
      <h2 class="serif">Nos bastidores,<br>uma operação excepcional</h2>
      <p class="lead">Os seus convidados terão uma recepção premium do início ao fim.</p>
    </div>
    <div class="feat-grid">
      <div class="feat reveal">
        <span class="fnum">01</span>
        <div class="ic"><svg viewBox="0 0 24 24"><path d="M12 2.5l7 3v5.5c0 4.4-3 8.2-7 10-4-1.8-7-5.6-7-10V5.5l7-3z"/><path d="M9.2 12l1.9 1.9 3.8-3.8"/></svg></div>
        <h3 class="serif">Segurança especializada</h3>
      </div>
      <div class="feat reveal d1">
        <span class="fnum">02</span>
        <div class="ic"><svg viewBox="0 0 24 24"><path d="M12 21s-7-5.5-7-11a7 7 0 0114 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></div>
        <h3 class="serif">Localização privilegiada</h3>
      </div>
      <div class="feat reveal d2">
        <span class="fnum">03</span>
        <div class="ic"><svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3"/><circle cx="17" cy="9.5" r="2.3"/><path d="M3.5 19c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/><path d="M15 14.5c2.6.2 4.5 2 4.5 4.5"/></svg></div>
        <h3 class="serif">Equipe operacional</h3>
      </div>
      <div class="feat reveal d3">
        <span class="fnum">04</span>
        <div class="ic"><svg viewBox="0 0 24 24"><path d="M4 9v6h4l5 4V5L8 9H4z"/><path d="M17 8.5a4 4 0 010 7"/><path d="M19.5 6a7 7 0 010 12"/></svg></div>
        <h3 class="serif">Som e iluminação</h3>
      </div>
      <div class="feat reveal d3">
        <span class="fnum">05</span>
        <div class="ic"><svg viewBox="0 0 24 24"><path d="M3 8h12a2.5 2.5 0 100-5"/><path d="M3 12h16a2.5 2.5 0 110 5"/><path d="M3 16h8a2 2 0 110 4"/></svg></div>
        <h3 class="serif">Climatizadores</h3>
      </div>
    </div>
  </div>
</section>

<!-- CLIENTES -->
<section class="clientes section-pad">
  <div class="wrap">
    <div class="head-center reveal">
      <span class="eyebrow">Clientes</span>
      <h2 class="serif">Nossos Clientes</h2>
      <p class="lead">Parceiros que confiam na excelência do Páreo.</p>
    </div>
  </div>
  <div class="clientes-marquee" aria-label="Logotipos de clientes parceiros">
    <div class="clientes-track">
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-sportv.webp" alt="SporTV" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-souza-cruz.webp" alt="Souza Cruz" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-shell.webp" alt="Shell" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-oi.webp" alt="Oi" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-globo.webp" alt="Globo" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-bradesco.webp" alt="Bradesco" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-rio-open.webp" alt="Rio Open" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-bayer.webp" alt="Bayer" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-sadia.webp" alt="Sadia" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-ipiranga.webp" alt="Ipiranga" width={220} /></div>
      <div class="clientes-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-coca-cola.webp" alt="Coca-Cola" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-sportv.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-souza-cruz.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-shell.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-oi.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-globo.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-bradesco.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-rio-open.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-bayer.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-sadia.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-ipiranga.webp" alt="" width={220} /></div>
      <div class="clientes-logo" aria-hidden="true"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo-coca-cola.webp" alt="" width={220} /></div>
    </div>
  </div>
</section>

<!-- GALERIA -->
<section class="galeria section-pad">
  <div class="wrap">
    <div class="head-center reveal">
      <span class="eyebrow">Galeria</span>
      <h2 class="serif">Um convite visual</h2>
      <p class="lead">Conheça o Páreo antes mesmo de sua visita.</p>
    </div>
    <div class="gal-grid reveal" id="gallery">
      <figure class="g-wide g-tall"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-2.webp" alt="Ambiente da Páreo montado para evento" /></figure>
      <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-7.webp" alt="Lounge da Páreo" /></figure>
      <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-3.webp" alt="Salão preparado para plateia" /></figure>
      <figure class="g-tall"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-1.webp" alt="Detalhe arquitetônico do espaço" /></figure>
      <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-4.webp" alt="Montagem de auditório" /></figure>
      <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-6.webp" alt="Iluminação cênica do salão" /></figure>
      <figure class="g-wide"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-8.webp" alt="Vista ampla do evento" /></figure>
      <figure><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/gal-5.webp" alt="Ambiente lounge ao entardecer" /></figure>
    </div>
  </div>
</section>

<!-- CONTATO -->
<section class="contato section-pad" id="contato">
  <div class="wrap contato-grid">
    <div class="contato-text reveal">
      <span class="eyebrow">Contato</span>
      <h2 class="serif">Preparado para planejar seu próximo evento de sucesso?</h2>
      <p class="lead">Preencha o formulário para receber nosso contato.</p>
    </div>
    <div class="form-card reveal d1">
      <LeadForm
        formId="lead-form"
        prefix="ev"
        project={config.project_slug}
        submitUrl={config.forms['lead-form'].webhooks[0]}
        redirectUrl={config.forms['lead-form'].redirect_on_success}
        submitText="Enviar solicitação"
        honeypot
        fields={[
          { name: 'Nome',    type: 'text', placeholder: 'Nome',    required: true  },
          { name: 'Empresa', type: 'text', placeholder: 'Empresa', required: true },
          { name: 'WhatsApp', type: 'tel', placeholder: 'WhatsApp', required: true },
          { name: 'E-mail', type: 'email', placeholder: 'E-mail', required: true },
          { name: 'Tipo de evento', type: 'select', placeholder: '', required: true, full: true, options: [
            { value: '', label: 'Tipo de evento' },
            { value: 'Convenção corporativa', label: 'Convenção corporativa' },
            { value: 'Confraternização / Fim de ano', label: 'Confraternização / Fim de ano' },
            { value: 'Premiação', label: 'Premiação' },
            { value: 'Reunião de negócios', label: 'Reunião de negócios' },
            { value: 'Lançamento de produto', label: 'Lançamento de produto' },
            { value: 'Outro', label: 'Outro' }
          ] },
          { name: 'Data do evento', type: 'date', placeholder: 'Data do evento', required: true },
          { name: 'Convidados', type: 'number', placeholder: 'Nº de convidados', required: true },
          { name: 'Mensagem', type: 'textarea', placeholder: 'Detalhes adicionais (não obrigatório)', required: false, full: true }
        ]}
      />
    </div>
  </div>
</section>

</main>

<!-- FOOTER -->
<footer>
  <div class="f-logo"><Img src="https://media.dmove.com.br/clients/restaurantepareo/photos/logo.webp" alt="Páreo" /></div>
  <p class="copy">Copyright © 2026 Páreo · Todos os direitos reservados</p>
  <div class="by">Desenvolvido por <a href="https://dmove.com.br" target="_blank" rel="noopener noreferrer"><Img src="https://media.dmove.com.br/clients/dmove/photos/logo-dmove.webp" alt="Dmove" /></a></div>
</footer>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" aria-hidden="true">
  <button class="lb-close" id="lbClose" aria-label="Fechar">×</button>
  <button class="lb-nav lb-prev" id="lbPrev" aria-label="Anterior">‹</button>
  <Img src="/images/placeholder.jpg" alt="" />
  <button class="lb-nav lb-next" id="lbNext" aria-label="Próximo">›</button>
</div>


</Base>
<script>
  import '../scripts/eventos-corporativos.js';
</script>
