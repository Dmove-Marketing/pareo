---
// src/components/forms/LeadForm.astro
import 'flatpickr/dist/flatpickr.min.css';

interface FieldOption {
  value: string;
  label: string;
  disabled?: boolean;
  selected?: boolean;
}

interface Field {
  name: string;
  type: 'text' | 'email' | 'tel' | 'number' | 'select' | 'textarea' | 'hidden' | 'date';
  label?: string;
  placeholder?: string;
  required?: boolean;
  full?: boolean;
  id?: string;
  autocomplete?: string;
  errorText?: string;
  errorId?: string;
  maxlength?: number;
  min?: string;
  max?: string;
  readonly?: boolean;
  rows?: number;
  options?: FieldOption[];
  value?: string;
  mask?: 'phone';
}

interface FieldRow {
  type: 'row';
  fields: Field[];
}

type AnyField = Field | FieldRow;

interface Props {
  formId: string;
  project: string;
  apiUrl?: string;
  submitUrl?: string;
  redirectUrl?: string;
  submitText?: string;
  fields?: AnyField[];
  class?: string;
  prefix?: string;
  gridId?: string;
  submitId?: string;
  honeypot?: boolean;
  successTitle?: string;
  successText?: string;
}

const EVENT_TYPE_OPTIONS: FieldOption[] = [
  { value: '',                                     label: 'Tipo de evento',                      disabled: true, selected: true },
  { value: 'Aniversário',                          label: 'Aniversário' },
  { value: 'Aniversário debutante',                label: 'Aniversário debutante' },
  { value: 'Bodas',                                label: 'Bodas' },
  { value: 'Casamento',                            label: 'Casamento' },
  { value: 'Confraternização corporativa',         label: 'Confraternização corporativa' },
  { value: 'Confraternização social',              label: 'Confraternização social' },
  { value: 'Corporativo',                          label: 'Corporativo' },
  { value: 'Feiras e Exposições',                  label: 'Feiras e Exposições' },
  { value: 'Formatura',                            label: 'Formatura' },
  { value: 'Happy Hours',                          label: 'Happy Hours' },
  { value: 'Masterclass e Palestras',              label: 'Masterclass e Palestras' },
  { value: 'Mentorias e Treinamentos',             label: 'Mentorias e Treinamentos' },
  { value: 'Offsite corporativo',                  label: 'Offsite corporativo' },
  { value: 'Reuniões de Networking',               label: 'Reuniões de Networking' },
  { value: 'Shows e Festivais',                    label: 'Shows e Festivais' },
  { value: 'Workshops, Conferências e Seminários', label: 'Workshops, Conferências e Seminários' },
  { value: 'Outros',                               label: 'Outros' },
];

const {
  formId,
  project,
  apiUrl = '',
  submitUrl,
  redirectUrl,
  submitText = 'Enviar',
  fields = [
    { name: 'Nome',           type: 'text',     placeholder: 'Nome',                                       required: true,  autocomplete: 'name' },
    { name: 'WhatsApp',       type: 'text',     placeholder: 'WhatsApp',                                   required: true,  autocomplete: 'tel', mask: 'phone' },
    { name: 'E-mail',         type: 'email',    placeholder: 'E-mail',                                     required: true,  autocomplete: 'email' },
    { name: 'Tipo de evento', type: 'select',   placeholder: '',                                           required: true,  options: EVENT_TYPE_OPTIONS },
    { name: 'Data do evento', type: 'date',     placeholder: 'Data do evento',                             required: true },
    { name: 'Convidados',     type: 'number',   placeholder: 'Nº de convidados',                           required: true,  min: '1' },
    { name: 'Mensagem',       type: 'textarea', placeholder: 'Detalhes adicionais (não obrigatório)',      required: false },
  ] as AnyField[],
  class: className,
  prefix = '',
  gridId,
  submitId,
  honeypot = false,
  successTitle = 'Solicitação recebida',
  successText  = 'Recebemos seu pedido.<br>Em breve entraremos em contato pelo WhatsApp ou e-mail.',
} = Astro.props;

const formElemId  = `form-${formId}`;
const theGridId   = gridId   || (prefix ? `${prefix}FormGrid`  : `${formId}Grid`);
const theSubmitId = submitId || (prefix ? `${prefix}SubmitBtn` : `${formId}SubmitBtn`);
const theSuccessId = prefix ? `${prefix}Success`  : `${formId}Success`;
const theMsgId     = prefix ? `${prefix}FormMsg`  : `${formId}FormMsg`;

const p        = prefix ? prefix : null;
const cxGrid   = p ? `${p}-form-grid`   : 'lead-form-grid';
const cxRow    = p ? `${p}-form-row`    : 'form-row';
const cxLabel  = p ? `${p}-label`       : 'form-label';
const cxInput  = p ? `${p}-input`       : 'form-input';
const cxSelect = p ? `${p}-select`      : 'form-select';
const cxArea   = p ? `${p}-textarea`    : 'form-textarea';
const cxError  = p ? `${p}-field-error` : 'field-error';
const cxMsg    = p ? `${p}-form-msg`    : 'form-error';
const cxFooter = p ? `${p}-form-footer` : 'form-footer';
const cxSuccess = p ? `${p}-success-state` : 'form-success-state';
const cxSIcon   = p ? `${p}-success-icon`  : 'form-success-icon';
const cxSTitle  = p ? `${p}-success-title` : 'form-success-title';
const cxSText   = p ? `${p}-success-text`  : 'form-success-text';
const cxSubmit  = p ? `${p}-submit form-submit` : 'btn btn-primary form-submit';
const groupCls  = (full?: boolean) => {
  const base = p ? `${p}-form-group` : 'form-group';
  return full ? `${base} full` : base;
};

function renderField(f: Field, cxInputClass: string, cxSelectClass: string, cxAreaClass: string) {
  // date type: text input with data-datepicker attribute
  if (f.type === 'date') {
    return { isDate: true };
  }
  return { isDate: false };
}
---

<form
  id={formElemId}
  name={formId}
  class:list={[!prefix && 'lead-form', className]}
  data-form-id={formId}
  data-project={project}
  data-api-url={apiUrl}
  data-submit-url={submitUrl}
  data-redirect={redirectUrl}
  data-grid-id={theGridId}
  data-success-id={theSuccessId}
  novalidate
>
  {honeypot && (
    <div class="hp-field" aria-hidden="true">
      <label for={`${formId}_website`}>Deixe este campo em branco</label>
      <input type="text" id={`${formId}_website`} name="website" tabindex="-1" autocomplete="off" />
    </div>
  )}

  <div class={cxGrid} id={theGridId}>
    {fields.map((fieldOrRow) => {
      if (fieldOrRow.type === 'row') {
        const row = fieldOrRow as FieldRow;
        return (
          <div class={cxRow}>
            {row.fields.map((f) => (
              <div class={groupCls(f.full)}>
                {f.label && <label class={cxLabel} for={f.id ?? f.name}>{f.label}</label>}
                {f.type === 'select' ? (
                  <select class={cxSelect} name={f.name} id={f.id ?? f.name} required={f.required}>
                    {f.options?.map((opt) => (
                      <option value={opt.value} disabled={opt.disabled} selected={opt.selected}>{opt.label}</option>
                    ))}
                  </select>
                ) : f.type === 'textarea' ? (
                  <textarea class={cxArea} name={f.name} id={f.id ?? f.name} rows={f.rows ?? 4} placeholder={f.placeholder} required={f.required}></textarea>
                ) : f.type === 'hidden' ? (
                  <input type="hidden" name={f.name} id={f.id ?? f.name} value={f.value} />
                ) : f.type === 'date' ? (
                  <input class={cxInput} type="text" name={f.name} id={f.id ?? f.name} placeholder={f.placeholder} required={f.required} readonly data-datepicker autocomplete="off" />
                ) : (
                  <input
                    class={cxInput}
                    type={f.type === 'date' ? 'text' : f.type}
                    name={f.name}
                    id={f.id ?? f.name}
                    placeholder={f.placeholder}
                    required={f.required}
                    autocomplete={f.autocomplete}
                    maxlength={f.maxlength}
                    min={f.min}
                    max={f.max}
                    readonly={f.readonly}
                    data-mask={f.mask}
                  />
                )}
                {f.errorText && <span class={cxError} id={f.errorId}>{f.errorText}</span>}
              </div>
            ))}
          </div>
        );
      }

      const f = fieldOrRow as Field;

      if (f.type === 'hidden') {
        return <input type="hidden" name={f.name} id={f.id ?? f.name} value={f.value} />;
      }

      return (
        <div class={groupCls(f.full)}>
          {f.label && <label class={cxLabel} for={f.id ?? f.name}>{f.label}</label>}
          {f.type === 'select' ? (
            <select class={cxSelect} name={f.name} id={f.id ?? f.name} required={f.required}>
              {f.options?.map((opt) => (
                <option value={opt.value} disabled={opt.disabled} selected={opt.selected}>{opt.label}</option>
              ))}
            </select>
          ) : f.type === 'textarea' ? (
            <textarea class={cxArea} name={f.name} id={f.id ?? f.name} rows={f.rows ?? 4} placeholder={f.placeholder} required={f.required}></textarea>
          ) : f.type === 'date' ? (
            <input class={cxInput} type="text" name={f.name} id={f.id ?? f.name} placeholder={f.placeholder} required={f.required} readonly data-datepicker autocomplete="off" />
          ) : (
            <input
              class={cxInput}
              type={f.type}
              name={f.name}
              id={f.id ?? f.name}
              placeholder={f.placeholder}
              required={f.required}
              autocomplete={f.autocomplete}
              maxlength={f.maxlength}
              min={f.min}
              max={f.max}
              readonly={f.readonly}
              data-mask={f.mask}
            />
          )}
          {f.errorText && <span class={cxError} id={f.errorId}>{f.errorText}</span>}
        </div>
      );
    })}

    <div class={groupCls(true)}>
      <button type="button" class={cxSubmit} id={theSubmitId}>
        <span class="btn-text">{submitText}</span>
        <span class="btn-loading" style="display:none;">
          <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
          </svg>
          Enviando...
        </span>
      </button>
    </div>

    <div class={cxMsg} id={theMsgId}></div>
    <p class={cxFooter}>Ao enviar, você concorda com nossa política de privacidade.</p>
  </div>

  <div class={cxSuccess} id={theSuccessId}>
    <div class={cxSIcon}>
      <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
    </div>
    <h3 class={cxSTitle}>{successTitle}</h3>
    <p class={cxSText} set:html={successText}></p>
  </div>
</form>

<script>
  import { initForms } from '../../scripts/forms.ts';
  import flatpickr from 'flatpickr';
  import { Portuguese } from 'flatpickr/dist/l10n/pt.js';

  flatpickr.localize(Portuguese);

  function applyPhoneMask(input: HTMLInputElement) {
    input.addEventListener('input', () => {
      let v = input.value.replace(/\D/g, '').slice(0, 11);
      if (v.length > 10) {
        v = v.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
      } else if (v.length > 6) {
        v = v.replace(/^(\d{2})(\d{4})(\d*)/, '($1) $2-$3');
      } else if (v.length > 2) {
        v = v.replace(/^(\d{2})(\d*)/, '($1) $2');
      } else if (v.length > 0) {
        v = v.replace(/^(\d*)/, '($1');
      }
      input.value = v;
    });
  }

  function initExtras() {
    // Flatpickr em todos os campos de data
    document.querySelectorAll<HTMLInputElement>('[data-datepicker]').forEach((el) => {
      if ((el as any)._flatpickr) return;
      flatpickr(el, {
        dateFormat: 'd/m/Y',
        minDate: 'today',
        disableMobile: false,
        allowInput: false,
      });
    });

    // Máscara de telefone
    document.querySelectorAll<HTMLInputElement>('[data-mask="phone"]').forEach((el) => {
      if (el.dataset.maskInit) return;
      el.dataset.maskInit = '1';
      applyPhoneMask(el);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { initForms(); initExtras(); });
  } else {
    initForms();
    initExtras();
  }
</script>

<style>
  .lead-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
    width: 100%;
    max-width: 440px;
  }

  .lead-form-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md, 1rem);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary, #111);
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border, #d1d5db);
    border-radius: 6px;
    font-size: 0.95rem;
    background: #fff;
    color: var(--text-primary, #111);
    transition: border-color 0.15s;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-primary, #2563eb);
  }

  .field-error {
    font-size: 0.78rem;
    color: #ef4444;
    display: none;
  }

  .field-error.visible { display: block; }

  .form-submit {
    width: 100%;
    margin-top: var(--space-sm, 0.5rem);
    font-size: 1.05rem;
    padding: 14px var(--space-xl, 2rem);
    cursor: pointer;
  }

  .form-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none !important;
  }

  .btn-loading {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .spinner { animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .form-error {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 4px;
    display: none;
  }

  .form-success-state {
    text-align: center;
    padding: var(--space-xl, 2rem);
    display: none;
  }

  .form-success-state.active { display: block; }

  .form-success-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md, 1rem);
    background: var(--gradient-primary, #2563eb);
    border-radius: 50%;
    color: white;
  }

  .form-success-icon svg {
    width: 28px;
    height: 28px;
    stroke: white;
    fill: none;
    stroke-width: 2.5;
  }

  .form-success-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary, #111);
    margin-bottom: 4px;
  }

  .form-success-text {
    color: var(--text-secondary, #666);
    font-size: 0.9rem;
  }

  .form-footer {
    font-size: 0.75rem;
    color: var(--text-secondary, #888);
    text-align: center;
  }
</style>
