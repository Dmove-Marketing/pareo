---
// src/components/ui/WhatsAppFloat.astro
// Botão flutuante de WhatsApp com tracking de clique
// Uso: <WhatsAppFloat phone="5511999999999" message="Olá!" />

interface Props {
  phone: string;
  message?: string;
  position?: 'bottom-right' | 'bottom-left';
  showAfterMs?: number;
  class?: string;
}

const {
  phone,
  message = 'Olá! Gostaria de saber mais.',
  position = 'bottom-right',
  showAfterMs = 2000,
  class: className,
} = Astro.props;

const whatsappUrl = `https://wa.me/${phone.replace(/\D/g, '')}?text=${encodeURIComponent(message)}`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class:list={['whatsapp-float', `whatsapp-${position}`, className]}
  data-cta="whatsapp-float"
  data-show-after={showAfterMs}
  aria-label="Falar pelo WhatsApp"
>
  <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="whatsapp-icon">
    <path d="M16.004 2.667A13.28 13.28 0 002.667 15.907a13.18 13.18 0 001.794 6.64L2.667 29.333l7.03-1.842a13.28 13.28 0 006.307 1.604h.005A13.28 13.28 0 0029.333 15.92 13.28 13.28 0 0016.004 2.667zm0 24.32a11.04 11.04 0 01-5.626-1.54l-.404-.24-4.186 1.098 1.116-4.08-.264-.42a11.01 11.01 0 01-1.69-5.898A11.05 11.05 0 0116.004 4.902 11.05 11.05 0 0127.1 15.92a11.05 11.05 0 01-11.096 11.067zm6.073-8.287c-.333-.167-1.972-.973-2.278-1.084-.306-.111-.53-.167-.752.167-.223.333-.862 1.084-1.057 1.306-.195.223-.39.25-.723.083-.333-.167-1.406-.518-2.678-1.652-.99-.882-1.658-1.972-1.852-2.305-.195-.333-.021-.514.146-.68.15-.15.333-.39.5-.584.167-.195.222-.334.333-.556.111-.223.056-.417-.028-.584-.083-.167-.751-1.812-1.03-2.48-.27-.65-.546-.562-.751-.573-.195-.01-.417-.012-.64-.012a1.228 1.228 0 00-.89.417c-.305.334-1.168 1.14-1.168 2.779 0 1.64 1.196 3.224 1.363 3.446.167.223 2.352 3.593 5.7 5.038.796.344 1.418.55 1.903.704.8.254 1.527.218 2.102.132.641-.096 1.972-.806 2.25-1.584.278-.779.278-1.446.195-1.585-.083-.139-.306-.223-.64-.39z" fill="currentColor"/>
  </svg>
  <span class="whatsapp-pulse"></span>
</a>

<script>
  function initWhatsApp() {
    const btn = document.querySelector('.whatsapp-float') as HTMLElement;
    if (!btn) return;

    const delay = parseInt(btn.dataset.showAfter || '2000');

    setTimeout(() => {
      btn.classList.add('whatsapp-visible');
    }, delay);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWhatsApp);
  } else {
    initWhatsApp();
  }
</script>

<style>
  .whatsapp-float {
    position: fixed;
    z-index: 1000;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #25D366;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0;
    transform: scale(0.5) translateY(20px);
    pointer-events: none;
  }

  .whatsapp-float.whatsapp-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  .whatsapp-float:hover {
    transform: scale(1.1) translateY(-2px);
    box-shadow: 0 6px 30px rgba(37, 211, 102, 0.6);
  }

  .whatsapp-bottom-right {
    bottom: 24px;
    right: 24px;
  }

  .whatsapp-bottom-left {
    bottom: 24px;
    left: 24px;
  }

  .whatsapp-icon {
    width: 32px;
    height: 32px;
  }

  .whatsapp-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(37, 211, 102, 0.3);
    animation: whatsapp-pulse 2s ease-in-out infinite;
    z-index: -1;
  }

  @keyframes whatsapp-pulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.15); opacity: 0; }
  }

  @media (max-width: 768px) {
    .whatsapp-float {
      width: 52px;
      height: 52px;
      bottom: 16px;
      right: 16px;
    }
    .whatsapp-icon {
      width: 28px;
      height: 28px;
    }
  }
</style>
