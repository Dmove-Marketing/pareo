---
// src/components/ui/Footer.astro
// Footer com links, social icons e copyright
// Uso: <Footer companyName="Dmove" />

interface Props {
  companyName?: string;
  links?: Array<{ text: string; href: string; }>;
  socialLinks?: Array<{ platform: string; url: string; }>;
  class?: string;
}

const {
  companyName = 'Empresa',
  links = [],
  socialLinks = [],
  class: className,
} = Astro.props;

const currentYear = new Date().getFullYear();

const socialIcons: Record<string, string> = {
  instagram: 'M7.8 2h8.4C19 2 22 5 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C5 22 2 19 2 16.2V7.8A5.8 5.8 0 017.8 2zm-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6zm9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM12 7a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6z',
  facebook: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z',
  linkedin: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 2a2 2 0 110 4 2 2 0 010-4z',
  twitter: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z',
  youtube: 'M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.43zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z',
  tiktok: 'M9 12a4 4 0 104 4V4a5 5 0 005 5',
};
---

<footer class:list={['site-footer', className]}>
  <div class="container footer-inner">
    <div class="footer-main">
      <div class="footer-brand">
        <span class="footer-company">{companyName}</span>
      </div>

      {links.length > 0 && (
        <nav class="footer-links">
          {links.map(link => (
            <a href={link.href} class="footer-link">{link.text}</a>
          ))}
        </nav>
      )}

      {socialLinks.length > 0 && (
        <div class="footer-social">
          {socialLinks.map(social => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social-link"
              aria-label={social.platform}
              data-cta={`social-${social.platform}`}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={socialIcons[social.platform] || ''} />
              </svg>
            </a>
          ))}
        </div>
      )}
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        © {currentYear} {companyName}. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-3xl) 0 var(--space-xl);
    border-top: 1px solid var(--glass-border);
    background: var(--bg-secondary);
  }

  .footer-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: var(--space-xl);
  }

  .footer-company {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .footer-links {
    display: flex;
    gap: var(--space-xl);
  }

  .footer-link {
    font-size: 0.9rem;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  .footer-social {
    display: flex;
    gap: var(--space-md);
  }

  .footer-social-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--glass-bg);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
    border: 1px solid var(--glass-border);
  }

  .footer-social-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  .footer-bottom {
    text-align: center;
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: var(--text-muted) !important;
  }

  @media (max-width: 768px) {
    .footer-main {
      flex-direction: column;
      text-align: center;
      gap: var(--space-lg);
    }

    .footer-links {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
