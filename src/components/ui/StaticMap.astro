---
interface Props {
  /** URL de embed do Google Maps (iframe src) */
  src: string;
  /** Altura do mapa em px (padrão: 400) */
  height?: number;
  class?: string;
}

const { src, height = 400, class: className } = Astro.props;
---

<div class:list={['static-map', className]} style={`height:${height}px`}>
  <iframe
    src={src}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    aria-hidden="true"
    tabindex="-1"
    title="Localização"
  ></iframe>
  <div class="static-map__overlay" aria-hidden="true"></div>
</div>

<style>
  .static-map {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: inherit;
  }
  .static-map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    pointer-events: none;
  }
  .static-map__overlay {
    position: absolute;
    inset: 0;
    cursor: default;
    z-index: 1;
  }
</style>
