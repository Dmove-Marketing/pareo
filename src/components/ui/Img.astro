---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  /** true = eager + fetchpriority high (use na imagem LCP/hero) */
  priority?: boolean;
  quality?: number;
  class?: string;
  style?: string;
}

const {
  src,
  alt,
  width = 1200,
  height,
  priority = false,
  quality = 80,
  class: className,
  style,
} = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{jpg,jpeg,png,webp,avif,gif}',
  { eager: true }
);

const key = `/src/assets/images/${src}`;
const mod = images[key];

if (!mod) {
  console.warn(`[Img] imagem não encontrada: ${key}`);
}
---

{mod ? (
  <Image
    src={mod.default}
    alt={alt}
    width={width}
    height={height}
    loading={priority ? 'eager' : 'lazy'}
    fetchpriority={priority ? 'high' : undefined}
    quality={quality}
    class={className}
    style={style}
  />
) : (
  <img
    src=""
    alt={alt}
    width={width}
    height={height ?? undefined}
    class={className}
    style={style}
    data-placeholder={key}
    aria-hidden="true"
  />
)}
